generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Fleet / Organization
model Fleet {
  id          String   @id @default(cuid())
  name        String
  description String?
  apiKey      String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  robots      Robot[]
}

// Core Robot entity
model Robot {
  id                  String   @id @default(cuid())
  name                String
  model               String?
  serialNumber        String   @unique
  did                 String   @unique // decentralized ID
  publicKey           String   // PEM
  privateKey          String   // PEM (encrypted in production)
  publicKeyHex        String
  hardwareFingerprint String
  status              String   @default("registered") // registered | active | offline | compromised | decommissioned
  trustScore          Int      @default(50)
  fleetId             String?
  fleet               Fleet?   @relation(fields: [fleetId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  firmwareRecords  FirmwareRecord[]
  telemetryEvents  TelemetryEvent[]
  auditLogs        AuditLog[]
  commands         Command[]
  softwareUpdates  SoftwareUpdate[]
  wallet           Wallet?
}

// Firmware verification records
model FirmwareRecord {
  id              String   @id @default(cuid())
  robotId         String
  robot           Robot    @relation(fields: [robotId], references: [id])
  version         String
  hash            String   // SHA-256 of firmware binary
  signature       String   // signed by robot's private key
  verified        Boolean  @default(false)
  previousHash    String?  // chain to previous firmware
  createdAt       DateTime @default(now())

  @@index([robotId])
}

// Telemetry events
model TelemetryEvent {
  id          String   @id @default(cuid())
  robotId     String
  robot       Robot    @relation(fields: [robotId], references: [id])
  eventType   String   // heartbeat | sensor | location | battery | error
  payload     String   // JSON
  hash        String   // SHA-256 of payload
  signature   String   // signed by robot
  verified    Boolean  @default(false)
  timestamp   DateTime @default(now())

  @@index([robotId])
  @@index([timestamp])
}

// Immutable audit log with hash chain
model AuditLog {
  id            String   @id @default(cuid())
  robotId       String
  robot         Robot    @relation(fields: [robotId], references: [id])
  action        String   // registered | firmware_updated | key_rotated | command_executed | anomaly_detected | status_changed
  details       String   // JSON
  hash          String   // SHA-256(previousHash + action + details + timestamp)
  previousHash  String?  // links to previous log entry
  signature     String   // signed by system
  timestamp     DateTime @default(now())

  @@index([robotId])
  @@index([timestamp])
}

// Commands sent to robots
model Command {
  id        String   @id @default(cuid())
  robotId   String
  robot     Robot    @relation(fields: [robotId], references: [id])
  type      String   // reboot | update | stop | start | diagnostic | custom
  payload   String?  // JSON
  status    String   @default("pending") // pending | sent | acknowledged | completed | failed
  issuedAt  DateTime @default(now())
  completedAt DateTime?

  @@index([robotId])
}


// OTA Software Updates
model SoftwareUpdate {
  id            String   @id @default(cuid())
  robotId       String
  robot         Robot    @relation(fields: [robotId], references: [id])
  version       String
  packageUrl    String
  packageHash   String
  status        String   @default("pending")
  scheduledAt   DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([robotId])
}

// Robot Wallet
model Wallet {
  id            String   @id @default(cuid())
  robotId       String   @unique
  robot         Robot    @relation(fields: [robotId], references: [id])
  address       String   @unique
  balance       Float    @default(0)
  permissions   String   @default("[\"read\"]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// RBAC User
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("viewer")
  fleetId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("free")
  maxRobots   Int      @default(10)
  maxFleets   Int      @default(1)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OrgMember {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  @@unique([orgId, userId])
  @@index([orgId])
}

// Webhooks
model Webhook {
  id        String   @id @default(cuid())
  fleetId   String
  url       String
  secret    String
  events    String   @default("[]") // JSON array of event types
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fleetId])
}

// Robot-to-Robot Transactions
model Transaction {
  id          String   @id @default(cuid())
  fromRobotId String
  toRobotId   String
  amount      Float
  type        String   @default("transfer")
  status      String   @default("pending")
  memo        String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([fromRobotId])
  @@index([toRobotId])
}
